{
  "$schema": "https://opencode.ai/config.json",
  "skills": {
    "paths": [".opencode/skills"]
  },
  "mcp": {
    "chrome-devtools": {
      "type": "local",
      "command": ["npx", "-y", "chrome-devtools-mcp@latest"]
    },
    "open-design": {
      "type": "local",
      "command": ["npx", "-y", "open-design-mcp"],
      "env": {
        "OD_DAEMON_URL": "http://localhost:7456"
      }
    }
  }
}
